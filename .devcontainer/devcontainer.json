{
    "name": "nfcore",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "FULLNAME": "${localEnv:FULLNAME}",
            "MAIL": "${localEnv:MAIL}",
            "USERNAME": "${localEnv:USER}",
            "USER_GID": "${localEnv:UID}",
            "USER_UID": "${localEnv:UID}"
        }
    },
    "runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined", "--privileged", "--cgroupns=host"],
    "containerEnv": {
        "LANG": "en_US.UTF-8",
        "LANGUAGE": "en_US.UTF-8",
        "LC_ALL": "en_US.UTF-8",
        "TZ": "Europe/Berlin"
    },
    // Configure tool-specific properties.
    "customizations": {
        // Configure properties specific to VS Code.
        "vscode": {
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
                "exiasr.hadolint",
                "gitlab.gitlab-workflow",
                "kahole.magit",
                "ms-vsliveshare.vsliveshare",
                "nf-core.nf-core-extensionpack",
                "pomdtr.secrets",
                "redhat.vscode-yaml"
            ]
        }
    },
    // Use 'postCreateCommand' to run commands after the container is created
    "postStartCommand": "nohup bash -c 'sudo dockerd &'",
    // Comment out to connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
    "remoteUser": "${localEnv:USER}"
}
